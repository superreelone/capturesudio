{
  "name": "ingestra-capturestudio",
  "productName": "Ingestra-CaptureStudio",
  "version": "0.1.4",
  "description": "Cross-platform screen recorder + screenshot app for content creators",
  "main": "./out/main/index.js",
  "author": "Ingestra",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/superreelone/capturesudio.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "assets:optimize": "node tools/build-assets/optimize-logo.mjs",
    "prebuild": "npm run assets:optimize",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,html}\"",
    "keygen:genkey": "node tools/keygen/keygen.mjs genkey",
    "keygen:issue": "node tools/keygen/keygen.mjs issue",
    "predist": "npm run build",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "bmp-js": "^0.1.0",
    "docx": "^8.5.0",
    "electron-store": "8.2.0",
    "electron-updater": "^6.3.4",
    "ffmpeg-static": "^5.2.0",
    "pdf-lib": "^1.17.1",
    "utif": "^3.1.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bmp-js": "^0.1.2",
    "@types/node": "22.5.0",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@types/web-bluetooth": "^0.0.20",
    "@typescript-eslint/eslint-plugin": "8.5.0",
    "@typescript-eslint/parser": "8.5.0",
    "@vitejs/plugin-react": "4.3.1",
    "electron": "32.0.1",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "electron-vite": "2.3.0",
    "eslint": "8.57.0",
    "eslint-plugin-react": "7.35.2",
    "eslint-plugin-react-hooks": "4.6.2",
    "png-to-ico": "^2.1.8",
    "prettier": "3.3.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.33.5",
    "typescript": "5.5.4",
    "vite": "5.4.2",
    "vitest": "^2.0.5"
  }
}
